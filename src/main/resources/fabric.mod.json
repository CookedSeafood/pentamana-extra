{
    "schemaVersion": 1,
    "id": "pentamana-extra",
    "version": "${version}",
    "name": "Pentamana Extra",
    "description": "A Pentamana addon providing mana calculation modifying features.",
    "authors": [
        {
            "name": "CookedSeafood",
            "contact": {
                "homepage": "https://github.com/CookedSeafood"
            }
        }
    ],
    "contact": {
        "homepage": "https://modrinth.com/mod/pentamana-extra",
        "sources": "https://github.com/CookedSeafood/pentamana-extra",
        "issues": "https://github.com/CookedSeafood/pentamana-extra/issues"
    },
    "license": "GNU-GPL-3.0",
    "icon": "assets/pentamana-extra/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "net.hederamc.pentamanaextra.PentamanaExtra"
        ],
        "client": [
            "net.hederamc.pentamanaextra.PentamanaExtraClient"
        ]
    },
    "mixins": [
